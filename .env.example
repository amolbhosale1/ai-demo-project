# Ollama (local LLM + embeddings — do not point at cloud providers)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_LLM_MODEL=llama3.2:3b
OLLAMA_EMBEDDING_MODEL=nomic-embed-text:latest

# Qdrant (localhost only via docker-compose.qdrant.yml)
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION_NAME=company_info
QDRANT_VECTOR_SIZE=768
QDRANT_API_KEY=

# RAG chunking / retrieval
RAG_TOP_K=5
RAG_CHUNK_SIZE=500
RAG_CHUNK_OVERLAP=100
RAG_DATASET_DIR=src/rag/dataset

# GDPR / Privacy
GDPR_PSEUDONYMIZE=true
GDPR_PSEUDONYM_SALT=change-me-in-production
GDPR_SENSITIVITY=standard
GDPR_EXCLUDE_FIELDS=
GDPR_RETENTION_DAYS=365
GDPR_QUERY_LOG_PII=false
GDPR_AUDIT_LOG_PATH=logs/rag_audit.jsonl
RAG_DEFAULT_ROLE=employee
